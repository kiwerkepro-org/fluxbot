# ─────────────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
*.bak
*.tmp
/tmp/

# ─────────────────────────────────────────────────────────────────────────────
#  Vault – AES-256-GCM Secret Storage (NIEMALS committen!)
# ─────────────────────────────────────────────────────────────────────────────
# workspace/* deckt diese bereits ab, aber explizit für Klarheit:
.secrets.vault
.vaultkey
**/.secrets.vault
**/.vaultkey

# ─────────────────────────────────────────────────────────────────────────────
#  Zusätzliches Hardening (Vorschlag)
# ─────────────────────────────────────────────────────────────────────────────
*.pem
*.key
*.crt
*.pub
auth_token.txt
credentials.json
/logs/
# Lokale Session-Notizen
INBOX.md

# Agent-Gedächtnis
memory-md/
